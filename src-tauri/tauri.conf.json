{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Little Tank",
  "version": "0.0.0",
  "identifier": "com.littletank.demo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:desktop-data && npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173"
  },
  "app": {},
  "bundle": {
    "active": true,
    "targets": "nsis",
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
